# On AppArmor hosts the passt profile attaches to the container pasta by
# pathname (profiles are not container-namespaced) and denies the netns
# and sysctl reads that Void pasta needs during nested build RUN steps
# (dmesg: profile="passt" DENIED).  slirp4netns is unaffected, as on the
# older-podman slots — force it as this slot's rootless network backend.
RUN printf '\n[network]\ndefault_rootless_network_cmd = "slirp4netns"\n' \
        >> /etc/containers/containers.conf
